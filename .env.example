# ============================================
# Crypto Digest Bot — Настройка переменных
# ============================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#
# Строки с # — комментарии. Не ставьте кавычки вокруг значений.

# ────────────────────────────────────────────
# 1. TELEGRAM BOT (для публикации постов)
# ────────────────────────────────────────────
# Создайте бота через @BotFather в Telegram → /newbot
# Скопируйте токен вида 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
DATA_DIR=./data
LOGS_DIR=./logs
PROFILES_DIR=./profiles

TELEGRAM_BOT_TOKEN=

# ID или @username канала, куда бот будет публиковать посты
# Формат: @my_channel или -1001234567890
# Бот должен быть добавлен в канал как администратор с правом публикации
# Это fallback для профиля `default`. Дополнительные каналы настраиваются в data/channel_profiles.json
TELEGRAM_CHANNEL_ID=

# Ваш личный Chat ID для получения постов на ревью
# Узнать: напишите @userinfobot в Telegram — он покажет ваш ID
# Один или несколько Chat ID для ревью: 123456789 или 123456789,987654321
TELEGRAM_ADMIN_CHAT_ID=

# ────────────────────────────────────────────
# 2. TELEGRAM MTPROTO (для чтения чужих каналов)
# ────────────────────────────────────────────
# Зайдите на https://my.telegram.org → API development tools
# Создайте приложение и скопируйте API ID (числовой) и API Hash
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Строка сессии — заполняется автоматически после запуска:
#   node src/setup.js
# Используется и для чтения каналов, и для публикации в канал через user account / MTProto.
# Если на этом аккаунте есть Telegram Premium, custom emoji будут публиковаться корректно.
TELEGRAM_SESSION_STRING=

# ────────────────────────────────────────────
# 3. AI — Основная модель (Google Gemini)
# ────────────────────────────────────────────
# Основной способ: храните Gemini-ключи в data/gemini_keys.json
# Формат файла:
# {
#   "keys": ["key_1", "key_2", "key_3"]
# }
#
# GEMINI_API_KEY / GEMINI_API_KEYS остаются только как bootstrap/fallback,
# если data/gemini_keys.json ещё не создан.
GEMINI_API_KEY=
GEMINI_API_KEYS=

# Модель (менять не нужно, если не знаете зачем)
GEMINI_MODEL=gemini-2.5-flash

# ────────────────────────────────────────────
# 4. API АНАЛИТИКИ (опционально)
# ────────────────────────────────────────────
# Birdeye — аналитика трендовых токенов
# Получить: https://birdeye.so → Developer → API Keys
BIRDEYE_API_KEY=

# Путь к браузеру для рендера CryptoPanic (если пусто, бот попробует найти Edge/Chrome сам)
HEADLESS_BROWSER_PATH=

# Сколько часов считать новости CryptoPanic актуальными
CRYPTOPANIC_MAX_AGE_HOURS=18

# Dune Analytics — on-chain метрики
# Получить: https://dune.com → Settings → API Keys
DUNE_API_KEY=

# ────────────────────────────────────────────
# 5. РЕЖИМЫ РАБОТЫ
# ────────────────────────────────────────────
# true = посты публикуются автоматически, false = только через ревью
AUTO_PUBLISH=false

# true = перед публикацией пост отправляется вам на одобрение
REVIEW_MODE=true

# Уровень логирования: error, warn, info, debug
LOG_LEVEL=info

# ────────────────────────────────────────────
# 6. РАСПИСАНИЕ И ЛИМИТЫ
# ────────────────────────────────────────────
# Часовой пояс для расписания публикаций
TIMEZONE=Europe/Moscow

# Минимальный интервал между постами (минуты)
MIN_POST_INTERVAL_MINUTES=30

# Сколько дней хранить скачанные медиафайлы
MEDIA_CACHE_DAYS=7

# Сколько изображений прикладывать к одному посту по умолчанию
TG_MAX_MEDIA_PER_POST=1

# За сколько часов назад парсить посты из каналов
LOOKBACK_HOURS=24
